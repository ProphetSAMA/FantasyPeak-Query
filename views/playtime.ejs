<%- include('partials/header') %>

<div class="space-y-6">
  <!-- 页面标题 -->
  <div class="border-b border-gray-200 dark:border-gray-700 pb-5">
    <h1 class="text-3xl font-bold leading-tight tracking-tight text-gray-900 dark:text-gray-100">
      <svg class="inline-block mr-3 h-8 w-8 text-minecraft-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      <%= title %>
    </h1>
    <p class="mt-2 text-sm text-gray-500 dark:text-gray-400">
      服务器中游戏时长最长的玩家排名
    </p>
  </div>

  <!-- 排行榜 -->
  <div class="bg-white dark:bg-gray-800 shadow rounded-lg overflow-hidden">
    <% if (players && players.length > 0) { %>
      <div class="overflow-x-auto">
        <table class="mc-table min-w-full divide-y divide-gray-200 dark:divide-gray-700">
          <thead class="bg-gray-50 dark:bg-gray-700">
            <tr>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
                排名
              </th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
                玩家
              </th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
                游戏时长
              </th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
                最后在线
              </th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
                状态
              </th>
            </tr>
          </thead>
          <tbody class="bg-white dark:bg-gray-800 divide-y divide-gray-200 dark:divide-gray-700">
            <% players.forEach(function(player, index) { %>
              <tr class="hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors">
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="flex items-center">
                    <% if (index === 0) { %>
                      <span class="inline-flex items-center justify-center h-8 w-8 rounded-full bg-yellow-100 text-yellow-800 font-bold text-sm">
                        🥇
                      </span>
                    <% } else if (index === 1) { %>
                      <span class="inline-flex items-center justify-center h-8 w-8 rounded-full bg-gray-100 text-gray-800 font-bold text-sm">
                        🥈
                      </span>
                    <% } else if (index === 2) { %>
                      <span class="inline-flex items-center justify-center h-8 w-8 rounded-full bg-orange-100 text-orange-800 font-bold text-sm">
                        🥉
                      </span>
                    <% } else { %>
                      <span class="inline-flex items-center justify-center h-8 w-8 rounded-full bg-gray-100 dark:bg-gray-600 text-gray-600 dark:text-gray-300 font-medium text-sm">
                        <%= index + 1 %>
                      </span>
                    <% } %>
                  </div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="flex items-center">
                    <div class="flex-shrink-0 h-10 w-10">
                      <img class="h-10 w-10 rounded-full" src="<%= getAvatarUrl(player.UUID, 40) %>" alt="<%= player.userName %>" loading="lazy">
                    </div>
                    <div class="ml-4">
                      <div class="text-sm font-medium text-gray-900 dark:text-gray-100">
                        <a href="/player/<%= player.UUID %>" class="hover:text-minecraft-grass dark:hover:text-minecraft-diamond transition-colors">
                          <%= player.userName %>
                        </a>
                      </div>
                    </div>
                  </div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="text-sm text-gray-900 dark:text-gray-100 font-semibold">
                    <%= formatPlaytime(player.playTime) %>
                  </div>
                  <% if (player.playTime) { %>
                    <div class="text-xs text-gray-500 dark:text-gray-400">
                      <%= Math.floor(player.playTime / 3600000) %> 小时
                    </div>
                  <% } %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 dark:text-gray-400">
                  <%= formatDate(player.lastOnline) %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <% if (player.online) { %>
                    <span class="inline-flex items-center rounded-full bg-green-100 dark:bg-green-900 px-2.5 py-0.5 text-xs font-medium text-green-800 dark:text-green-200">
                      <span class="mr-1.5 h-2 w-2 rounded-full bg-green-400 animate-pulse"></span>
                      在线
                    </span>
                  <% } else { %>
                    <span class="inline-flex items-center rounded-full bg-gray-100 dark:bg-gray-700 px-2.5 py-0.5 text-xs font-medium text-gray-800 dark:text-gray-300">
                      离线
                    </span>
                  <% } %>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>

      <!-- 统计信息 -->
      <div class="bg-gray-50 dark:bg-gray-700 px-6 py-4 border-t border-gray-200 dark:border-gray-600">
        <div class="flex flex-wrap gap-6">
          <div>
            <span class="text-sm text-gray-500 dark:text-gray-400">总玩家数:</span>
            <span class="ml-2 text-sm font-semibold text-gray-900 dark:text-gray-100"><%= players.length %></span>
          </div>
          <div>
            <span class="text-sm text-gray-500 dark:text-gray-400">总游戏时长:</span>
            <span class="ml-2 text-sm font-semibold text-minecraft-diamond">
              <%= formatPlaytime(players.reduce((sum, p) => sum + (p.playTime || 0), 0)) %>
            </span>
          </div>
        </div>
      </div>
    <% } else { %>
      <div class="text-center py-12">
        <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <h3 class="mt-2 text-sm font-medium text-gray-900 dark:text-gray-100">暂无数据</h3>
        <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
          暂无玩家游戏时长数据
        </p>
      </div>
    <% } %>
  </div>
</div>

<%- include('partials/footer') %>
