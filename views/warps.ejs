<%- include('partials/header') %>

<div class="space-y-6">
  <!-- 页面标题 -->
  <div class="border-b border-gray-200 dark:border-gray-700 pb-5">
    <h1 class="text-3xl font-bold leading-tight tracking-tight text-gray-900 dark:text-gray-100">
      <svg class="inline-block mr-3 h-8 w-8 text-minecraft-diamond" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
      </svg>
      <%= title %>
    </h1>
    <p class="mt-2 text-sm text-gray-500 dark:text-gray-400">
      服务器中所有可用的传送点，点击坐标可快速复制
    </p>
  </div>

  <!-- 传送点列表 -->
  <% if (warps && warps.length > 0) { %>
    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
      <% warps.forEach(function(warp, index) { %>
        <div class="mc-card bg-white dark:bg-gray-800 shadow rounded-lg overflow-hidden animate-on-scroll"
             style="animation-delay: <%= index * 0.05 %>s">
          <div class="px-6 py-5">
            <div class="flex items-center justify-between mb-4">
              <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100">
                <svg class="inline-block mr-2 h-5 w-5 text-minecraft-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" />
                </svg>
                <%= warp.name %>
              </h3>
            </div>

            <div class="space-y-3">
              <!-- 世界 -->
              <div class="flex items-center text-sm">
                <span class="text-gray-500 dark:text-gray-400 w-16">世界:</span>
                <span class="text-gray-900 dark:text-gray-100 font-medium">
                  <svg class="inline-block mr-1 h-4 w-4 text-minecraft-grass" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                  <%= warp.world %>
                </span>
              </div>

              <!-- 坐标 -->
              <div class="flex items-center text-sm">
                <span class="text-gray-500 dark:text-gray-400 w-16">坐标:</span>
                <button onclick="copyToClipboard('<%= Math.round(warp.x) %>, <%= Math.round(warp.y) %>, <%= Math.round(warp.z) %>')"
                        class="text-minecraft-diamond hover:text-minecraft-grass transition-colors font-mono text-sm"
                        title="点击复制坐标">
                  <svg class="inline-block mr-1 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3" />
                  </svg>
                  (<%= Math.round(warp.x) %>, <%= Math.round(warp.y) %>, <%= Math.round(warp.z) %>)
                </button>
              </div>
            </div>
          </div>
        </div>
      <% }); %>
    </div>

    <!-- 统计信息 -->
    <div class="bg-white dark:bg-gray-800 shadow rounded-lg p-4">
      <p class="text-sm text-gray-500 dark:text-gray-400">
        共有 <span class="font-semibold text-minecraft-diamond"><%= warps.length %></span> 个传送点
      </p>
    </div>
  <% } else { %>
    <div class="bg-white dark:bg-gray-800 shadow rounded-lg overflow-hidden">
      <div class="text-center py-12">
        <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
        </svg>
        <h3 class="mt-2 text-sm font-medium text-gray-900 dark:text-gray-100">没有传送点</h3>
        <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
          服务器中暂无可用的传送点
        </p>
      </div>
    </div>
  <% } %>
</div>

<%- include('partials/footer') %>
