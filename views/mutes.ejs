<%- include('partials/header') %>

<div class="space-y-6">
  <!-- 页面标题 -->
  <div class="border-b border-gray-200 dark:border-gray-700 pb-5">
    <h1 class="text-3xl font-bold leading-tight tracking-tight text-gray-900 dark:text-gray-100">
      <%= title %>
    </h1>
  </div>

  <!-- 搜索框和链接 -->
  <div class="bg-white dark:bg-gray-800 shadow rounded-lg p-6">
    <div class="flex flex-col sm:flex-row gap-4 items-center justify-between">
      <form action="/bans/search" method="GET" class="flex gap-4 flex-1">
        <div class="flex-1">
          <input type="text" name="keyword" value="<%= keyword || '' %>" placeholder="搜索禁言记录..." class="block w-full rounded-md border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-gray-100 shadow-sm focus:border-minecraft-gold focus:ring-minecraft-gold sm:text-sm px-4 py-3 border">
        </div>
        <button type="submit" class="inline-flex items-center rounded-md border border-transparent bg-minecraft-gold px-4 py-2 text-sm font-medium text-white shadow-sm hover:bg-yellow-600 focus:outline-none focus:ring-2 focus:ring-minecraft-gold focus:ring-offset-2 transition-colors">
          <svg class="-ml-1 mr-2 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
          搜索
        </button>
      </form>
      <a href="/bans" class="inline-flex items-center rounded-md border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 px-4 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 shadow-sm hover:bg-gray-50 dark:hover:bg-gray-600 focus:outline-none focus:ring-2 focus:ring-minecraft-redstone focus:ring-offset-2 transition-colors">
        <svg class="-ml-1 mr-2 h-5 w-5 text-minecraft-redstone" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636" />
        </svg>
        查看封禁记录
      </a>
    </div>
  </div>

  <!-- 禁言列表 -->
  <div class="bg-white dark:bg-gray-800 shadow rounded-lg overflow-hidden">
    <% if (mutes && mutes.length > 0) { %>
      <div class="overflow-x-auto">
        <table class="mc-table min-w-full divide-y divide-gray-200 dark:divide-gray-700">
          <thead class="bg-gray-50 dark:bg-gray-700">
            <tr>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
                玩家
              </th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
                原因
              </th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
                禁言者
              </th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
                时间
              </th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
                时长
              </th>
            </tr>
          </thead>
          <tbody class="bg-white dark:bg-gray-800 divide-y divide-gray-200 dark:divide-gray-700">
            <% mutes.forEach(function(mute) { %>
              <tr class="hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors">
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="flex items-center">
                    <div class="flex-shrink-0 h-10 w-10">
                      <img class="h-10 w-10 rounded-full" src="<%= getAvatarUrl(mute.UUID, 40) %>" alt="<%= mute.UUID %>" loading="lazy">
                    </div>
                    <div class="ml-4">
                      <div class="text-sm font-medium text-gray-900 dark:text-gray-100">
                        <a href="/player/<%= mute.UUID %>" class="hover:text-minecraft-grass dark:hover:text-minecraft-diamond transition-colors">
                          <%= mute.UUID %>
                        </a>
                      </div>
                    </div>
                  </div>
                </td>
                <td class="px-6 py-4">
                  <div class="text-sm text-gray-900 dark:text-gray-100"><%= mute.reason || '未指定' %></div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 dark:text-gray-400">
                  <%= mute.mutedBy || '控制台' %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 dark:text-gray-400">
                  <%= formatDate(mute.muteTime) %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 dark:text-gray-400">
                  <% if (mute.duration && mute.duration > 0) { %>
                    <%= Math.floor(mute.duration / 3600000) %> 小时
                  <% } else if (mute.duration === -1) { %>
                    <span class="text-yellow-600 dark:text-yellow-400 font-medium">永久</span>
                  <% } else { %>
                    未知
                  <% } %>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>

      <!-- 分页 -->
      <%- include('partials/pagination', { pagination: pagination, keyword: keyword }) %>
    <% } else { %>
      <div class="text-center py-12">
        <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <h3 class="mt-2 text-sm font-medium text-gray-900 dark:text-gray-100">没有禁言记录</h3>
        <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
          <% if (keyword) { %>
            没有找到匹配 "<%= keyword %>" 的禁言记录
          <% } else { %>
            暂无禁言数据
          <% } %>
        </p>
      </div>
    <% } %>
  </div>
</div>

<%- include('partials/footer') %>
