<%- include('partials/header') %>

<div class="flex min-h-full flex-col justify-center px-6 py-12 lg:px-8">
  <div class="sm:mx-auto sm:w-full sm:max-w-md">
    <div class="bg-white shadow rounded-lg p-8 text-center">
      <svg class="mx-auto h-16 w-16 text-minecraft-redstone" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L3.34 16.5c-.77.833.192 2.5 1.732 2.5z" />
      </svg>
      <h1 class="mt-4 text-3xl font-bold text-gray-900"><%= title %></h1>
      <p class="mt-2 text-lg text-gray-600"><%= message %></p>
      <% if (error && error.stack && process.env.NODE_ENV === 'development') { %>
        <div class="mt-6 p-4 bg-gray-100 rounded-lg text-left">
          <pre class="text-xs text-gray-700 overflow-auto"><%= error.stack %></pre>
        </div>
      <% } %>
      <div class="mt-8">
        <a href="/" class="inline-flex items-center rounded-md border border-transparent bg-minecraft-grass px-6 py-3 text-base font-medium text-white shadow-sm hover:bg-minecraft-dirt transition-colors">
          返回首页
        </a>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
