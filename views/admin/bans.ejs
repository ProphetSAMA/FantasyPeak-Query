<%- include('../partials/header') %>

<div class="space-y-6">
  <!-- 页面标题 -->
  <div class="border-b border-gray-200 dark:border-gray-700 pb-5">
    <div class="flex items-center justify-between">
      <h1 class="text-3xl font-bold leading-tight tracking-tight text-gray-900 dark:text-gray-100">
        封禁管理
      </h1>
      <a href="/admin" class="inline-flex items-center rounded-md border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 px-4 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 shadow-sm hover:bg-gray-50 dark:hover:bg-gray-600 transition-colors">
        <svg class="-ml-1 mr-2 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
        返回管理后台
      </a>
    </div>
  </div>

  <!-- 封禁列表 -->
  <div class="bg-white dark:bg-gray-800 shadow rounded-lg overflow-hidden">
    <% if (bans && bans.length > 0) { %>
      <div class="overflow-x-auto">
        <table class="mc-table min-w-full divide-y divide-gray-200 dark:divide-gray-700">
          <thead class="bg-gray-50 dark:bg-gray-700">
            <tr>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
                玩家
              </th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
                原因
              </th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
                封禁者
              </th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
                时间
              </th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
                时长
              </th>
              <th scope="col" class="relative px-6 py-3">
                <span class="sr-only">操作</span>
              </th>
            </tr>
          </thead>
          <tbody class="bg-white dark:bg-gray-800 divide-y divide-gray-200 dark:divide-gray-700">
            <% bans.forEach(function(ban) { %>
              <tr class="hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors">
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="flex items-center">
                    <div class="flex-shrink-0 h-10 w-10">
                      <img class="h-10 w-10 rounded-full" src="<%= getAvatarUrl(ban.UUID, 40, ban.userName) %>" alt="<%= ban.UUID %>" loading="lazy">
                    </div>
                    <div class="ml-4">
                      <div class="text-sm font-medium text-gray-900 dark:text-gray-100">
                        <a href="/player/<%= ban.UUID %>" class="hover:text-minecraft-grass dark:hover:text-minecraft-diamond transition-colors">
                          <%= ban.UUID %>
                        </a>
                      </div>
                    </div>
                  </div>
                </td>
                <td class="px-6 py-4">
                  <div class="text-sm text-gray-900 dark:text-gray-100"><%= ban.reason || '未指定' %></div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 dark:text-gray-400">
                  <%= ban.bannedBy || '控制台' %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 dark:text-gray-400">
                  <%= formatDate(ban.banTime) %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 dark:text-gray-400">
                  <% if (ban.duration && ban.duration > 0) { %>
                    <%= Math.floor(ban.duration / 3600000) %> 小时
                  <% } else if (ban.duration === -1) { %>
                    <span class="text-red-600 dark:text-red-400 font-medium">永久</span>
                  <% } else { %>
                    未知
                  <% } %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                  <a href="/player/<%= ban.UUID %>" class="text-minecraft-grass hover:text-minecraft-dirt dark:text-minecraft-diamond dark:hover:text-minecraft-grass transition-colors">
                    查看玩家
                  </a>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>

      <!-- 分页 -->
      <%- include('../partials/pagination', { pagination: pagination, keyword: '' }) %>
    <% } else { %>
      <div class="text-center py-12">
        <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <h3 class="mt-2 text-sm font-medium text-gray-900 dark:text-gray-100">没有封禁记录</h3>
        <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">暂无封禁数据</p>
      </div>
    <% } %>
  </div>
</div>

<%- include('../partials/footer') %>
