<%- include('partials/header') %>

<div class="space-y-6">
  <!-- 页面标题 -->
  <div class="border-b border-gray-200 dark:border-gray-700 pb-5">
    <h1 class="text-3xl font-bold leading-tight tracking-tight text-gray-900 dark:text-gray-100">
      <%= title %>
    </h1>
  </div>

  <!-- 统计卡片 -->
  <% if (stats) { %>
    <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-4">
      <div class="overflow-hidden rounded-lg bg-white dark:bg-gray-800 shadow">
        <div class="p-5">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <div class="flex h-12 w-12 items-center justify-center rounded-full bg-red-100 dark:bg-red-900">
                <svg class="h-6 w-6 text-red-600 dark:text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636" />
                </svg>
              </div>
            </div>
            <div class="ml-5 w-0 flex-1">
              <dl>
                <dt class="truncate text-sm font-medium text-gray-500 dark:text-gray-400">总封禁数</dt>
                <dd class="mt-1 text-3xl font-semibold text-gray-900 dark:text-gray-100"><%= stats.totalBans %></dd>
              </dl>
            </div>
          </div>
        </div>
      </div>

      <div class="overflow-hidden rounded-lg bg-white dark:bg-gray-800 shadow">
        <div class="p-5">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <div class="flex h-12 w-12 items-center justify-center rounded-full bg-orange-100 dark:bg-orange-900">
                <svg class="h-6 w-6 text-orange-600 dark:text-orange-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
            </div>
            <div class="ml-5 w-0 flex-1">
              <dl>
                <dt class="truncate text-sm font-medium text-gray-500 dark:text-gray-400">活跃封禁</dt>
                <dd class="mt-1 text-3xl font-semibold text-gray-900 dark:text-gray-100"><%= stats.activeBans %></dd>
              </dl>
            </div>
          </div>
        </div>
      </div>

      <div class="overflow-hidden rounded-lg bg-white dark:bg-gray-800 shadow">
        <div class="p-5">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <div class="flex h-12 w-12 items-center justify-center rounded-full bg-yellow-100 dark:bg-yellow-900">
                <svg class="h-6 w-6 text-yellow-600 dark:text-yellow-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5.586 15H4a1 1 0 01-1-1v-4a1 1 0 011-1h1.586l4.707-4.707C10.923 3.663 12 4.109 12 5v14c0 .891-1.077 1.337-1.707.707L5.586 15z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2" />
                </svg>
              </div>
            </div>
            <div class="ml-5 w-0 flex-1">
              <dl>
                <dt class="truncate text-sm font-medium text-gray-500 dark:text-gray-400">总禁言数</dt>
                <dd class="mt-1 text-3xl font-semibold text-gray-900 dark:text-gray-100"><%= stats.totalMutes %></dd>
              </dl>
            </div>
          </div>
        </div>
      </div>

      <div class="overflow-hidden rounded-lg bg-white dark:bg-gray-800 shadow">
        <div class="p-5">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <div class="flex h-12 w-12 items-center justify-center rounded-full bg-purple-100 dark:bg-purple-900">
                <svg class="h-6 w-6 text-purple-600 dark:text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
            </div>
            <div class="ml-5 w-0 flex-1">
              <dl>
                <dt class="truncate text-sm font-medium text-gray-500 dark:text-gray-400">活跃禁言</dt>
                <dd class="mt-1 text-3xl font-semibold text-gray-900 dark:text-gray-100"><%= stats.activeMutes %></dd>
              </dl>
            </div>
          </div>
        </div>
      </div>
    </div>
  <% } %>

  <!-- 搜索框和链接 -->
  <div class="bg-white dark:bg-gray-800 shadow rounded-lg p-6">
    <div class="flex flex-col sm:flex-row gap-4 items-center justify-between">
      <form action="/bans/search" method="GET" class="flex gap-4 flex-1">
        <div class="flex-1">
          <input type="text" name="keyword" value="<%= keyword || '' %>" placeholder="搜索封禁记录..." class="block w-full rounded-md border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-gray-100 shadow-sm focus:border-minecraft-redstone focus:ring-minecraft-redstone sm:text-sm px-4 py-3 border">
        </div>
        <button type="submit" class="inline-flex items-center rounded-md border border-transparent bg-minecraft-redstone px-4 py-2 text-sm font-medium text-white shadow-sm hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-minecraft-redstone focus:ring-offset-2 transition-colors">
          <svg class="-ml-1 mr-2 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
          搜索
        </button>
      </form>
      <a href="/bans/mutes" class="inline-flex items-center rounded-md border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 px-4 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 shadow-sm hover:bg-gray-50 dark:hover:bg-gray-600 focus:outline-none focus:ring-2 focus:ring-minecraft-gold focus:ring-offset-2 transition-colors">
        <svg class="-ml-1 mr-2 h-5 w-5 text-minecraft-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5.586 15H4a1 1 0 01-1-1v-4a1 1 0 011-1h1.586l4.707-4.707C10.923 3.663 12 4.109 12 5v14c0 .891-1.077 1.337-1.707.707L5.586 15z" />
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2" />
        </svg>
        查看禁言记录
      </a>
    </div>
  </div>

  <!-- 封禁列表 -->
  <div class="bg-white dark:bg-gray-800 shadow rounded-lg overflow-hidden">
    <% if (bans && bans.length > 0) { %>
      <div class="overflow-x-auto">
        <table class="mc-table min-w-full divide-y divide-gray-200 dark:divide-gray-700">
          <thead class="bg-gray-50 dark:bg-gray-700">
            <tr>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
                玩家
              </th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
                原因
              </th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
                封禁者
              </th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
                时间
              </th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
                时长
              </th>
            </tr>
          </thead>
          <tbody class="bg-white dark:bg-gray-800 divide-y divide-gray-200 dark:divide-gray-700">
            <% bans.forEach(function(ban) { %>
              <tr class="hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors">
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="flex items-center">
                    <div class="flex-shrink-0 h-10 w-10">
                      <img class="h-10 w-10 rounded-full" src="<%= getAvatarUrl(ban.UUID, 40) %>" alt="<%= ban.userName || ban.UUID %>" loading="lazy">
                    </div>
                    <div class="ml-4">
                      <div class="text-sm font-medium text-gray-900 dark:text-gray-100">
                        <a href="/player/<%= ban.UUID %>" class="hover:text-minecraft-grass dark:hover:text-minecraft-diamond transition-colors">
                          <%= ban.userName || ban.UUID %>
                        </a>
                      </div>
                    </div>
                  </div>
                </td>
                <td class="px-6 py-4">
                  <div class="text-sm text-gray-900 dark:text-gray-100"><%= ban.reason || '未指定' %></div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 dark:text-gray-400">
                  <%= ban.bannedBy || '控制台' %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 dark:text-gray-400">
                  <%= formatDate(ban.banTime) %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 dark:text-gray-400">
                  <% if (ban.duration && ban.duration > 0) { %>
                    <%= Math.floor(ban.duration / 3600000) %> 小时
                  <% } else if (ban.duration === -1) { %>
                    <span class="text-red-600 dark:text-red-400 font-medium">永久</span>
                  <% } else { %>
                    未知
                  <% } %>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>

      <!-- 分页 -->
      <%- include('partials/pagination', { pagination: pagination, keyword: keyword }) %>
    <% } else { %>
      <div class="text-center py-12">
        <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <h3 class="mt-2 text-sm font-medium text-gray-900 dark:text-gray-100">没有封禁记录</h3>
        <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
          <% if (keyword) { %>
            没有找到匹配 "<%= keyword %>" 的封禁记录
          <% } else { %>
            暂无封禁数据
          <% } %>
        </p>
      </div>
    <% } %>
  </div>
</div>

<%- include('partials/footer') %>
