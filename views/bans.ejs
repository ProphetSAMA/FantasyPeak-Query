<%- include('partials/header') %>

<div class="space-y-6">
  <!-- 页面标题 -->
  <div class="border-b border-gray-200 pb-5">
    <h1 class="text-3xl font-bold leading-tight tracking-tight text-gray-900">
      <%= title %>
    </h1>
  </div>

  <!-- 统计卡片 -->
  <% if (stats) { %>
    <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-4">
      <div class="overflow-hidden rounded-lg bg-white shadow">
        <div class="p-5">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <div class="flex h-12 w-12 items-center justify-center rounded-full bg-red-100">
                <svg class="h-6 w-6 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636" />
                </svg>
              </div>
            </div>
            <div class="ml-5 w-0 flex-1">
              <dl>
                <dt class="truncate text-sm font-medium text-gray-500">总封禁数</dt>
                <dd class="mt-1 text-3xl font-semibold text-gray-900"><%= stats.totalBans %></dd>
              </dl>
            </div>
          </div>
        </div>
      </div>

      <div class="overflow-hidden rounded-lg bg-white shadow">
        <div class="p-5">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <div class="flex h-12 w-12 items-center justify-center rounded-full bg-orange-100">
                <svg class="h-6 w-6 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
            </div>
            <div class="ml-5 w-0 flex-1">
              <dl>
                <dt class="truncate text-sm font-medium text-gray-500">活跃封禁</dt>
                <dd class="mt-1 text-3xl font-semibold text-gray-900"><%= stats.activeBans %></dd>
              </dl>
            </div>
          </div>
        </div>
      </div>

      <div class="overflow-hidden rounded-lg bg-white shadow">
        <div class="p-5">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <div class="flex h-12 w-12 items-center justify-center rounded-full bg-yellow-100">
                <svg class="h-6 w-6 text-yellow-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5.586 15H4a1 1 0 01-1-1v-4a1 1 0 011-1h1.586l4.707-4.707C10.923 3.663 12 4.109 12 5v14c0 .891-1.077 1.337-1.707.707L5.586 15z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2" />
                </svg>
              </div>
            </div>
            <div class="ml-5 w-0 flex-1">
              <dl>
                <dt class="truncate text-sm font-medium text-gray-500">总禁言数</dt>
                <dd class="mt-1 text-3xl font-semibold text-gray-900"><%= stats.totalMutes %></dd>
              </dl>
            </div>
          </div>
        </div>
      </div>

      <div class="overflow-hidden rounded-lg bg-white shadow">
        <div class="p-5">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <div class="flex h-12 w-12 items-center justify-center rounded-full bg-purple-100">
                <svg class="h-6 w-6 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
            </div>
            <div class="ml-5 w-0 flex-1">
              <dl>
                <dt class="truncate text-sm font-medium text-gray-500">活跃禁言</dt>
                <dd class="mt-1 text-3xl font-semibold text-gray-900"><%= stats.activeMutes %></dd>
              </dl>
            </div>
          </div>
        </div>
      </div>
    </div>
  <% } %>

  <!-- 搜索框和链接 -->
  <div class="bg-white shadow rounded-lg p-6">
    <div class="flex flex-col sm:flex-row gap-4 items-center justify-between">
      <form action="/bans/search" method="GET" class="flex gap-4 flex-1">
        <div class="flex-1">
          <input type="text" name="keyword" value="<%= keyword || '' %>" placeholder="搜索封禁记录..." class="block w-full rounded-md border-gray-300 shadow-sm focus:border-minecraft-redstone focus:ring-minecraft-redstone sm:text-sm px-4 py-3 border">
        </div>
        <button type="submit" class="inline-flex items-center rounded-md border border-transparent bg-minecraft-redstone px-4 py-2 text-sm font-medium text-white shadow-sm hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-minecraft-redstone focus:ring-offset-2 transition-colors">
          <svg class="-ml-1 mr-2 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
          搜索
        </button>
      </form>
      <a href="/bans/mutes" class="inline-flex items-center rounded-md border border-gray-300 bg-white px-4 py-2 text-sm font-medium text-gray-700 shadow-sm hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-minecraft-gold focus:ring-offset-2 transition-colors">
        <svg class="-ml-1 mr-2 h-5 w-5 text-minecraft-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5.586 15H4a1 1 0 01-1-1v-4a1 1 0 011-1h1.586l4.707-4.707C10.923 3.663 12 4.109 12 5v14c0 .891-1.077 1.337-1.707.707L5.586 15z" />
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2" />
        </svg>
        查看禁言记录
      </a>
    </div>
  </div>

  <!-- 封禁列表 -->
  <div class="bg-white shadow rounded-lg overflow-hidden">
    <% if (bans && bans.length > 0) { %>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                玩家
              </th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                原因
              </th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                封禁者
              </th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                时间
              </th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                时长
              </th>
            </tr>
          </thead>
          <tbody class="bg-white divide-y divide-gray-200">
            <% bans.forEach(function(ban) { %>
              <tr class="hover:bg-gray-50 transition-colors">
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="flex items-center">
                    <div class="flex-shrink-0 h-10 w-10">
                      <img class="h-10 w-10 rounded-full" src="https://mc-heads.net/avatar/<%= ban.UUID %>/40" alt="<%= ban.UUID %>">
                    </div>
                    <div class="ml-4">
                      <div class="text-sm font-medium text-gray-900">
                        <a href="/player/<%= ban.UUID %>" class="hover:text-minecraft-grass transition-colors">
                          <%= ban.UUID %>
                        </a>
                      </div>
                    </div>
                  </div>
                </td>
                <td class="px-6 py-4">
                  <div class="text-sm text-gray-900"><%= ban.reason || '未指定' %></div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                  <%= ban.bannedBy || '控制台' %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                  <%= new Date(ban.banTime).toLocaleString('zh-CN') %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                  <% if (ban.duration && ban.duration > 0) { %>
                    <%= Math.floor(ban.duration / 3600000) %> 小时
                  <% } else if (ban.duration === -1) { %>
                    <span class="text-red-600 font-medium">永久</span>
                  <% } else { %>
                    未知
                  <% } %>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>

      <!-- 分页 -->
      <% if (pagination && pagination.pages > 1) { %>
        <div class="bg-white px-4 py-3 flex items-center justify-between border-t border-gray-200 sm:px-6">
          <div class="flex-1 flex justify-between sm:hidden">
            <% if (pagination.page > 1) { %>
              <a href="?page=<%= pagination.page - 1 %><%= keyword ? '&keyword=' + keyword : '' %>" class="relative inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50">
                上一页
              </a>
            <% } %>
            <% if (pagination.page < pagination.pages) { %>
              <a href="?page=<%= pagination.page + 1 %><%= keyword ? '&keyword=' + keyword : '' %>" class="ml-3 relative inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50">
                下一页
              </a>
            <% } %>
          </div>
          <div class="hidden sm:flex-1 sm:flex sm:items-center sm:justify-between">
            <div>
              <p class="text-sm text-gray-700">
                显示第 <span class="font-medium"><%= (pagination.page - 1) * pagination.limit + 1 %></span> 到 <span class="font-medium"><%= Math.min(pagination.page * pagination.limit, pagination.total) %></span> 条，共 <span class="font-medium"><%= pagination.total %></span> 条
              </p>
            </div>
            <div>
              <nav class="relative z-0 inline-flex rounded-md shadow-sm -space-x-px" aria-label="Pagination">
                <% if (pagination.page > 1) { %>
                  <a href="?page=<%= pagination.page - 1 %><%= keyword ? '&keyword=' + keyword : '' %>" class="relative inline-flex items-center px-2 py-2 rounded-l-md border border-gray-300 bg-white text-sm font-medium text-gray-500 hover:bg-gray-50">
                    <span class="sr-only">上一页</span>
                    <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
                    </svg>
                  </a>
                <% } %>

                <% for (let i = Math.max(1, pagination.page - 2); i <= Math.min(pagination.pages, pagination.page + 2); i++) { %>
                  <% if (i === pagination.page) { %>
                    <span class="relative inline-flex items-center px-4 py-2 border border-minecraft-redstone bg-minecraft-redstone text-sm font-medium text-white">
                      <%= i %>
                    </span>
                  <% } else { %>
                    <a href="?page=<%= i %><%= keyword ? '&keyword=' + keyword : '' %>" class="relative inline-flex items-center px-4 py-2 border border-gray-300 bg-white text-sm font-medium text-gray-700 hover:bg-gray-50">
                      <%= i %>
                    </a>
                  <% } %>
                <% } %>

                <% if (pagination.page < pagination.pages) { %>
                  <a href="?page=<%= pagination.page + 1 %><%= keyword ? '&keyword=' + keyword : '' %>" class="relative inline-flex items-center px-2 py-2 rounded-r-md border border-gray-300 bg-white text-sm font-medium text-gray-500 hover:bg-gray-50">
                    <span class="sr-only">下一页</span>
                    <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                    </svg>
                  </a>
                <% } %>
              </nav>
            </div>
          </div>
        </div>
      <% } %>
    <% } else { %>
      <div class="text-center py-12">
        <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <h3 class="mt-2 text-sm font-medium text-gray-900">没有封禁记录</h3>
        <p class="mt-1 text-sm text-gray-500">
          <% if (keyword) { %>
            没有找到匹配 "<%= keyword %>" 的封禁记录
          <% } else { %>
            暂无封禁数据
          <% } %>
        </p>
      </div>
    <% } %>
  </div>
</div>

<%- include('partials/footer') %>
