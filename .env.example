# ============================
# 数据库配置
# ============================

# 数据库类型: mysql 或 sqlite（默认 mysql）
DB_TYPE=sqlite

# ---- MySQL 配置（DB_TYPE=mysql 时生效）----
DB_HOST=localhost
DB_PORT=3306
DB_USER=cmi_user
DB_PASSWORD=your_password_here
DB_NAME=cmi_database

# ---- SQLite 配置（DB_TYPE=sqlite 时生效）----
# 数据库文件路径，默认在项目目录下 data/minecraft.db
# SQLITE_PATH=./data/minecraft.db

# ============================
# 应用配置
# ============================

# 服务器端口
PORT=3000

# 运行环境: development 或 production
NODE_ENV=development

# 会话密钥（生产环境请修改为随机字符串）
SESSION_SECRET=your-secret-key-here

# 管理员账号
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# ============================
# 缓存配置
# ============================

# 缓存TTL（秒）
CACHE_TTL=300

# 缓存检查周期（秒）
CACHE_CHECK_PERIOD=600

# ============================
# 安全配置
# ============================

# 允许的来源（生产环境，逗号分隔）
# ALLOWED_ORIGINS=https://your-domain.com

# ============================
# 头像配置
# ============================

# 头像提供者: mc-heads（使用 mc-heads.net 官方服务）或 blessing（使用个人 BlessingSkin 皮肤站）
AVATAR_PROVIDER=mc-heads

# BlessingSkin 皮肤站地址（AVATAR_PROVIDER=blessing 时必填，不带末尾斜杠）
# BLESSING_SKIN_URL=https://skin.example.com
